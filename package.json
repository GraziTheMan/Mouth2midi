{
  "name": "mouth2midi",
  "version": "0.1.0",
  "description": "Vochlea/Dubler-style real-time voice-to-MIDI for Android (S24 Ultra), built on Oboe + YIN in C++ with a Vite/Capacitor UI.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:add": "cap add android",
    "cap:sync": "cap sync",
    "cap:open": "cap open android"
  },
  "keywords": [
    "midi",
    "voice-to-midi",
    "pitch-detection",
    "yin",
    "oboe",
    "capacitor",
    "android"
  ],
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
